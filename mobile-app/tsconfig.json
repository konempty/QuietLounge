{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../shared/types.ts",
    "../shared/block-list.ts"
  ],
  "exclude": [
    "shared/api-interceptor.ts",
    "shared/filter-engine.ts",
    "shared/ui-injector.ts",
    "shared/selectors.ts"
  ]
}
