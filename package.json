{
  "name": "lounge",
  "version": "1.0.0",
  "description": "네이버 라운지(`lounge.naver.com`)에서 특정 유저의 게시글을 숨기는 클라이언트 사이드 차단 도구.",
  "main": "tampermonkey-test.user.js",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "eslint shared chrome-extension tampermonkey-test.user.js",
    "lint:fix": "eslint shared chrome-extension tampermonkey-test.user.js --fix",
    "format": "prettier --write \"shared/**/*.ts\" \"chrome-extension/**/*.{js,json}\" \"*.user.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.8"
  }
}
